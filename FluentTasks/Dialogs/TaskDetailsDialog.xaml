<?xml version="1.0" encoding="utf-8"?>
<ContentDialog x:Class="FluentTasks.UI.Dialogs.TaskDetailsDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Uid="TaskDetailsDialog"
               Title="Task Details"
               PrimaryButtonText="Save"
               CloseButtonText="Cancel"
               DefaultButton="Primary"
               PrimaryButtonClick="Save_Click">

    <StackPanel Spacing="16"
                MinWidth="280"
                MaxWidth="500">
        <!-- Title -->
        <TextBox x:Name="TitleTextBox"
                 x:Uid="TaskTitleTextBox"
                 Header="Title"
                 PlaceholderText="Task title" />

        <!-- Due Date -->
        <StackPanel Spacing="8">
            <TextBlock x:Uid="DueDateTextBlock"
                       Text="Due Date"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CalendarDatePicker x:Name="DueDatePicker"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="No due date" />

                <Button x:Uid="ClearDueDateButton"
                        Grid.Column="1"
                        Content="Clear"
                        Click="ClearDueDate_Click" />
            </Grid>
        </StackPanel>

        <!-- Notes/Description -->
        <TextBox x:Name="NotesTextBox"
                 x:Uid="NotesTextBox"
                 Header="Notes"
                 PlaceholderText="Add details about this task..."
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="120"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />

        <!-- Status Info -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="TaskDetailsStatusLabelTextBlock"
                       Text="Status"
                       Style="{StaticResource CaptionTextBlockStyle}" />
            <TextBlock x:Name="StatusInfo"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
