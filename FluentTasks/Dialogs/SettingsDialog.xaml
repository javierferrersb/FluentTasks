<UserControl x:Class="FluentTasks.UI.Dialogs.SettingsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="32"
                    Padding="24,20"
                    MaxWidth="600">

            <!-- Header with optional hamburger button -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="HamburgerButton"
                        Grid.Column="0"
                        Click="HamburgerButton_Click"
                        VerticalAlignment="Center"
                        Padding="10"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Toggle navigation">
                    <FontIcon Glyph="&#xE700;"
                              FontSize="18" />
                </Button>

                <TextBlock Grid.Column="1"
                           Text="Settings"
                           Style="{StaticResource TitleLargeTextBlockStyle}"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Appearance Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Appearance"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <TextBlock Text="Choose how FluentTasks looks"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />

                <RadioButtons x:Name="ThemeRadioButtons">
                    <RadioButton Tag="Light">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12">
                            <FontIcon Glyph="&#xE706;"
                                      FontSize="20" />
                            <TextBlock Text="Light"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Tag="Dark">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12">
                            <FontIcon Glyph="&#xE708;"
                                      FontSize="20" />
                            <TextBlock Text="Dark"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Tag="Default">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12">
                            <FontIcon Glyph="&#xE770;"
                                      FontSize="20" />
                            <TextBlock Text="Use system setting"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </RadioButtons>
            </StackPanel>

            <!-- Lists Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Lists"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Spacing="12">
                    <ComboBox x:Name="DefaultFilterComboBox"
                              Header="Default filter"
                              HorizontalAlignment="Stretch"
                              MaxWidth="300">
                        <ComboBoxItem Content="All tasks"
                                      Tag="All" />
                        <ComboBoxItem Content="Incomplete"
                                      Tag="Incomplete" />
                        <ComboBoxItem Content="Completed"
                                      Tag="Completed" />
                        <ComboBoxItem Content="Overdue"
                                      Tag="Overdue" />
                        <ComboBoxItem Content="Today"
                                      Tag="Today" />
                        <ComboBoxItem Content="This week"
                                      Tag="ThisWeek" />
                    </ComboBox>

                    <ComboBox x:Name="DefaultSortComboBox"
                              Header="Default sort order"
                              HorizontalAlignment="Stretch"
                              MaxWidth="300">
                        <ComboBoxItem Content="None (my order)"
                                      Tag="None" />
                        <ComboBoxItem Content="Due date (soonest first)"
                                      Tag="DueDateAscending" />
                        <ComboBoxItem Content="Due date (latest first)"
                                      Tag="DueDateDescending" />
                        <ComboBoxItem Content="Alphabetical (A-Z)"
                                      Tag="Alphabetical" />
                        <ComboBoxItem Content="Alphabetical (Z-A)"
                                      Tag="AlphabeticalReverse" />
                        <ComboBoxItem Content="Completed last"
                                      Tag="CompletedLast" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Data Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Data"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Spacing="12">
                    <Button Click="ClearCache_Click">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE74D;"
                                      FontSize="16" />
                            <TextBlock Text="Clear cache" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Remove locally cached data. Your tasks will be re-downloaded on next sync."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,-4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Account Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Account"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Spacing="12">
                    <Button Click="LogOut_Click"
                            Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE7E8;"
                                      FontSize="16" />
                            <TextBlock Text="Log out" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Sign out of your Google account. You'll need to sign in again to access your tasks."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,-4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- About Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="About"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Spacing="16"
                            HorizontalAlignment="Left">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="VersionText"
                                   Text="Version 1.0.0"
                                   Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock Text="A modern, fluent task management application for Windows"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                            <Run Text="Created by " />
                            <Run Text="Javier Ferrer"
                                 FontWeight="SemiBold" />
                        </TextBlock>

                        <HyperlinkButton NavigateUri="https://github.com/javierferrersb/FluentTasks"
                                         Padding="0">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE774;"
                                          FontSize="16" />
                                <TextBlock Text="View on GitHub" />
                            </StackPanel>
                        </HyperlinkButton>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Built with"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="• WinUI 3"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="• .NET 10"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="• Windows App SDK"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="• Google Tasks API"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock x:Name="CopyrightText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Licensed under MIT License"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
