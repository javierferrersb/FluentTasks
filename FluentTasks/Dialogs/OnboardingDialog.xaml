<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="FluentTasks.UI.Dialogs.OnboardingDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <!-- FlipView for carousel pages -->
        <FlipView x:Name="OnboardingFlipView"
                  SelectionChanged="OnboardingFlipView_SelectionChanged">

            <!-- Page 1: Welcome -->
            <FlipViewItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="32"
                                    Padding="48"
                                    MaxWidth="600">

                            <!-- App Icon and Title -->
                            <StackPanel Spacing="16"
                                        HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/Square150x150Logo.png"
                                       Width="128"
                                       Height="128"
                                       HorizontalAlignment="Center" />

                                <TextBlock x:Uid="OnboardingWelcomeTitleBlock"
                                           Text="Welcome to FluentTasks"
                                           Style="{StaticResource TitleLargeTextBlockStyle}"
                                           FontSize="32"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />

                                <TextBlock x:Uid="OnboardingWelcomeSubtitleBlock"
                                           Text="A modern, native Google Tasks client for Windows"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </StackPanel>

                            <!-- Feature Cards -->
                            <Grid ColumnSpacing="16"
                                  RowSpacing="16"
                                  HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Feature Card 1: Sync -->
                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="20"
                                        MinWidth="180">
                                    <StackPanel Spacing="12">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Left">
                                            <FontIcon Glyph="&#xE895;"
                                                      FontSize="24"
                                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Uid="OnboardingFeatureSyncTitleBlock"
                                                   Text="Sync with Google"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock x:Uid="OnboardingFeatureSyncDescriptionBlock"
                                                   Text="Your tasks sync seamlessly with Google Tasks"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Feature Card 2: Organize -->
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="20"
                                        MinWidth="180">
                                    <StackPanel Spacing="12">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Left">
                                            <FontIcon Glyph="&#xE8A5;"
                                                      FontSize="24"
                                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Uid="OnboardingFeatureOrganizeTitleBlock"
                                                   Text="Stay Organized"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock x:Uid="OnboardingFeatureOrganizeDescriptionBlock"
                                                   Text="Create lists and subtasks to organize your work"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Feature Card 3: Due Dates -->
                                <Border Grid.Row="1"
                                        Grid.Column="0"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="20"
                                        MinWidth="180">
                                    <StackPanel Spacing="12">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Left">
                                            <FontIcon Glyph="&#xE787;"
                                                      FontSize="24"
                                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Uid="OnboardingFeatureDueDatesTitleBlock"
                                                   Text="Due Dates"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock x:Uid="OnboardingFeatureDueDatesDescriptionBlock"
                                                   Text="Set due dates and never miss a deadline"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Feature Card 4: Filter and Sort -->
                                <Border Grid.Row="1"
                                        Grid.Column="1"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="20"
                                        MinWidth="180">
                                    <StackPanel Spacing="12">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Left">
                                            <FontIcon Glyph="&#xE71C;"
                                                      FontSize="24"
                                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Uid="OnboardingFeatureFilterSortTitleBlock"
                                                   Text="Filter and Sort"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock x:Uid="OnboardingFeatureFilterSortDescriptionBlock"
                                                   Text="Find tasks quickly with powerful filters"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Navigation buttons -->
                    <Grid Grid.Row="1"
                          Padding="48,24"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Page indicators -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="Page1Indicator"
                                     Width="8"
                                     Height="8"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <Ellipse x:Name="Page2IndicatorWelcome"
                                     Width="8"
                                     Height="8"
                                     Fill="{ThemeResource ControlStrongFillColorDefaultBrush}"
                                     Opacity="0.4" />
                        </StackPanel>

                        <Button x:Uid="OnboardingGetStartedActionButton"
                                Grid.Column="2"
                                Content="Get Started"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="NextButton_Click"
                                HorizontalAlignment="Right"
                                Padding="24,10" />
                    </Grid>
                </Grid>
            </FlipViewItem>

            <!-- Page 2: Sign In -->
            <FlipViewItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="32"
                                    Padding="48"
                                    MaxWidth="500">

                            <!-- Sign In Icon -->
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="24"
                                    Width="96"
                                    Height="96"
                                    HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8FA;"
                                          FontSize="48"
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>

                            <!-- Sign In Text -->
                            <StackPanel Spacing="12"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Uid="OnboardingSignInTitleBlock"
                                           Text="Connect Your Account"
                                           Style="{StaticResource TitleLargeTextBlockStyle}"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />

                                <TextBlock x:Uid="OnboardingSignInDescriptionBlock"
                                           Text="Sign in with your Google account to sync your tasks across all your devices"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="400" />
                            </StackPanel>

                            <!-- Google Sign In Button -->
                            <Button x:Uid="OnboardingGoogleSignInButton"
                                    x:Name="GoogleSignInButton"
                                    Click="GoogleSignInButton_Click"
                                    HorizontalAlignment="Center"
                                    Padding="0"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                <Grid Padding="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Google Logo -->
                                    <Viewbox Width="20"
                                             Height="20"
                                             Margin="0,0,12,0">
                                        <Canvas Width="24"
                                                Height="24">
                                            <Path Fill="#4285F4"
                                                  Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                            <Path Fill="#34A853"
                                                  Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                            <Path Fill="#FBBC05"
                                                  Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                            <Path Fill="#EA4335"
                                                  Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                                        </Canvas>
                                    </Viewbox>

                                    <TextBlock Grid.Column="1"
                                               x:Uid="OnboardingSignInButtonTextBlock"
                                               Text="Sign in with Google"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <!-- Loading state -->
                            <StackPanel x:Name="SigningInPanel"
                                        Visibility="Collapsed"
                                        Spacing="16"
                                        HorizontalAlignment="Center">
                                <ProgressRing IsActive="True"
                                              Width="32"
                                              Height="32" />
                                <TextBlock x:Uid="OnboardingSigningInTextBlock"
                                           Text="Signing you in..."
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Privacy note -->
                            <StackPanel Spacing="8"
                                        HorizontalAlignment="Center"
                                        Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE72E;"
                                              FontSize="14"
                                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock x:Uid="OnboardingPrivacyTitleBlock"
                                               Text="Your data stays private"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <TextBlock x:Uid="OnboardingPrivacyDescriptionBlock"
                                           Text="All your data stays on your device and Google's servers. FluentTasks doesn't collect or store any personal information."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="350" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Navigation buttons -->
                    <Grid Grid.Row="1"
                          Padding="48,24"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Uid="OnboardingBackActionButton"
                                Content="Back"
                                Click="BackButton_Click"
                                HorizontalAlignment="Left"
                                Padding="24,10" />

                        <!-- Page indicators -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="Page1IndicatorSignIn"
                                     Width="8"
                                     Height="8"
                                     Fill="{ThemeResource ControlStrongFillColorDefaultBrush}"
                                     Opacity="0.4" />
                            <Ellipse x:Name="Page2Indicator"
                                     Width="8"
                                     Height="8"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </FlipViewItem>
        </FlipView>
    </Grid>
</UserControl>
