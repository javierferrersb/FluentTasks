<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FluentTasks.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FluentTasks.UI.Converters"
    xmlns:local="using:FluentTasks.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters (shared across all views and controls) -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
            <converters:DateToStringConverter x:Key="DateToStringConverter" />
            <converters:OverdueToColorConverter x:Key="OverdueToColorConverter" />
            <converters:OverdueToBackgroundConverter x:Key="OverdueToBackgroundConverter" />
            <converters:OverdueToBorderConverter x:Key="OverdueToBorderConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:SubtaskMarginConverter x:Key="SubtaskMarginConverter" />

            <!-- Task card border style -->
            <Style x:Key="TaskCardStyle"
                   TargetType="Border">
                <Setter Property="Background"
                        Value="{ThemeResource LayerFillColorDefaultBrush}" />
                <Setter Property="BorderBrush"
                        Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="CornerRadius"
                        Value="6" />
                <Setter Property="Padding"
                        Value="14,10" />
                <Setter Property="Margin"
                        Value="0,0,0,6" />
            </Style>

            <!-- Transparent action button style (subtask / details / delete) -->
            <Style x:Key="TaskActionButtonStyle"
                   TargetType="Button">
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderThickness"
                        Value="0" />
                <Setter Property="Padding"
                        Value="8" />
                <Setter Property="CornerRadius"
                        Value="4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid"
                                  Background="{TemplateBinding Background}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background"
                                                        Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background"
                                                        Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Skeleton task card template -->
            <DataTemplate x:Key="SkeletonTaskTemplate">
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,10"
                        Margin="0,0,0,6"
                        Height="60">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Width="20"
                                   Height="20"
                                   RadiusX="4"
                                   RadiusY="4"
                                   Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                   Opacity="0.3" />
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Rectangle Width="200"
                                       Height="14"
                                       RadiusX="2"
                                       RadiusY="2"
                                       Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                       HorizontalAlignment="Left"
                                       Opacity="0.3" />
                            <Rectangle Width="120"
                                       Height="10"
                                       RadiusX="2"
                                       RadiusY="2"
                                       Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                       HorizontalAlignment="Left"
                                       Opacity="0.2" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Skeleton nav item template for sidebar loading state -->
            <DataTemplate x:Key="SkeletonNavItemTemplate">
                <Grid Margin="4,2"
                      Padding="12,8"
                      MinHeight="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0"
                               Width="16"
                               Height="16"
                               RadiusX="4"
                               RadiusY="4"
                               Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                               Opacity="0.3"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Rectangle Grid.Column="1"
                               Height="14"
                               RadiusX="2"
                               RadiusY="2"
                               Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Opacity="0.3"
                               MaxWidth="160"
                               MinWidth="80" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
