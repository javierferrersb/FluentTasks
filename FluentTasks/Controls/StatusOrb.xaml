<UserControl x:Class="FluentTasks.UI.Controls.StatusOrb"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Width="12"
          Height="12">
        <!-- Ripple Effect (behind main orb) -->
        <Ellipse x:Name="RippleEllipse"
                 Width="12"
                 Height="12"
                 StrokeThickness="2"
                 Stroke="Transparent"
                 Fill="Transparent"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"
                 Opacity="0">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="RippleScale"
                                ScaleX="1"
                                ScaleY="1"
                                CenterX="6"
                                CenterY="6" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Main Orb -->
        <Ellipse x:Name="OrbEllipse"
                 Width="12"
                 Height="12"
                 StrokeThickness="2"
                 Fill="Transparent"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="OrbScale"
                                ScaleX="1"
                                ScaleY="1"
                                CenterX="6"
                                CenterY="6" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>