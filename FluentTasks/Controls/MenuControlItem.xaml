<UserControl x:Class="FluentTasks.UI.Controls.MenuItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:FluentTasks.UI.Controls"
             mc:Ignorable="d">

    <Button x:Name="RootButton"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Center"
            MinHeight="40"
            Margin="4,2"
            Padding="12,8"
            Style="{StaticResource SubtleButtonStyle}"
            Click="RootButton_Click"
            RightTapped="RootButton_RightTapped">
        <Button.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem x:Uid="EditMenuFlyoutItem"
                                Text="Edit"
                                Icon="Edit"
                                Click="EditContextMenuItem_Click" />
                <MenuFlyoutItem x:Uid="DeleteMenuFlyoutItem"
                                Text="Delete"
                                Icon="Delete"
                                Click="DeleteContextMenuItem_Click" />
            </MenuFlyout>
        </Button.ContextFlyout>
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon x:Name="ItemIcon"
                      Grid.Column="0"
                      Glyph="{x:Bind Icon, Mode=OneWay}"
                      FontSize="16"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Margin="0,0,12,0"
                      Foreground="{Binding Foreground, ElementName=RootButton}" />

            <TextBlock x:Name="ItemText"
                       Grid.Column="1"
                       Text="{x:Bind Text, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{Binding Foreground, ElementName=RootButton}" />

            <Button x:Uid="EditButton"
                    x:Name="EditButton"
                    Grid.Column="2"
                    Content="&#xE70F;"
                    FontFamily="Segoe MDL2 Assets"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Foreground="{Binding Foreground, ElementName=RootButton}"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Click="EditButton_Click"
                    ToolTipService.ToolTip="Edit list" />

            <Button x:Uid="DeleteButton"
                    x:Name="DeleteButton"
                    Grid.Column="3"
                    Content="&#xE74D;"
                    FontFamily="Segoe MDL2 Assets"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Foreground="{Binding Foreground, ElementName=RootButton}"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Click="DeleteButton_Click"
                    ToolTipService.ToolTip="Delete list" />
        </Grid>
    </Button>
</UserControl>
