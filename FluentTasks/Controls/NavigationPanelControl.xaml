<UserControl x:Class="FluentTasks.UI.Controls.NavigationPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:FluentTasks.UI.Controls"
             xmlns:models="using:FluentTasks.UI.Models">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="0,0,1,0"
		  CornerRadius="0,8,0,0" 
          Padding="8">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Smart Lists -->
        <ItemsControl Grid.Row="0"
                      x:Name="SmartListsView"
                      ItemsSource="{x:Bind SmartLists, Mode=OneWay}"
                      Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:NavItem">
                    <controls:MenuItemControl Icon="{x:Bind Icon}"
                                              Text="{x:Bind Title}"
                                              IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                                              ItemClicked="MenuItem_Clicked"
                                              Tag="{x:Bind}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- My Lists Header -->
		<Grid Grid.Row="1"
			  Padding="16,16,16,8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Text="My Lists"
					   Grid.Column="0"
					   Style="{StaticResource CaptionTextBlockStyle}"
					   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					   FontWeight="SemiBold" />
			<Button Content="&#xE710;"
					Grid.Column="1"
					FontFamily="Segoe MDL2 Assets"
					Click="CreateList_Click"
					Background="Transparent"
					BorderThickness="0"
					Padding="4"
					FontSize="12" />
		</Grid>

        <!-- User Lists -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="UserListsView"
                          ItemsSource="{x:Bind UserLists, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:NavItem">
                        <controls:MenuItemControl Icon="{x:Bind Icon}"
                                                  Text="{x:Bind Title}"
                                                  IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                                                  ShowActions="True"
                                                  ItemClicked="MenuItem_Clicked"
                                                  EditClicked="MenuItem_EditClicked"
                                                  DeleteClicked="MenuItem_DeleteClicked"
                                                  Tag="{x:Bind}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Settings -->
        <Button Grid.Row="3"
                Click="Settings_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="20,12"
                Margin="0,8,0,4">
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <FontIcon Glyph="&#xE713;"
                          FontSize="16" />
                <TextBlock Text="Settings" />
            </StackPanel>
        </Button>

        <!-- Sync -->
        <Button Grid.Row="4"
                Click="Sync_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="20,12"
                Margin="0,4,0,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <FontIcon Glyph="&#xE72C;"
                          FontSize="16" />
                <TextBlock Text="Sync Lists" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
