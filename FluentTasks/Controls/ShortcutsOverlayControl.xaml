<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="FluentTasks.UI.Controls.ShortcutsOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <Grid x:Name="OverlayRoot">
        <!-- Semi-transparent backdrop for dismissal -->
        <Border x:Name="Backdrop"
                Background="{ThemeResource SmokeFillColorDefaultBrush}"
                Tapped="Backdrop_Tapped"
                Opacity="0" />

        <!-- Centered overlay panel -->
        <Border x:Name="OverlayPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="860"
                MaxHeight="600"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="0"
                Opacity="0"
                Translation="0,20,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0"
                      Padding="28,20,20,12"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0"
                              Glyph="&#xEDA7;"
                              FontSize="20"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0" />

                    <TextBlock x:Uid="ShortcutsOverlayTitle"
                               Grid.Column="1"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center" />

                    <Button x:Uid="ShortcutsOverlayCloseButton"
                            Grid.Column="2"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8">
                        <FontIcon Glyph="&#xE711;"
                                  FontSize="12" />
                    </Button>
                </Grid>

                <!-- Shortcut columns -->
                <ScrollViewer Grid.Row="1"
                              Padding="28,16,28,8"
                              VerticalScrollBarVisibility="Auto">
                    <Grid ColumnSpacing="32"
                          RowSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Navigation column -->
                        <StackPanel Grid.Column="0"
                                    Spacing="4">
                            <TextBlock x:Name="NavigationCategoryHeader"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,8"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <ItemsRepeater x:Name="NavigationShortcuts">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="2" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5"
                                              ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"
                                                                  MinWidth="110" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Keys}"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Description}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Tasks column -->
                        <StackPanel Grid.Column="1"
                                    Spacing="4">
                            <TextBlock x:Name="TasksCategoryHeader"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,8"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <ItemsRepeater x:Name="TaskShortcuts">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="2" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5"
                                              ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"
                                                                  MinWidth="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Keys}"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Description}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- View and App column -->
                        <StackPanel Grid.Column="2"
                                    Spacing="4">
                            <TextBlock x:Name="ViewCategoryHeader"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,8"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <ItemsRepeater x:Name="ViewShortcuts">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="2" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5"
                                              ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"
                                                                  MinWidth="110" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Keys}"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Description}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Footer hint -->
                <Border Grid.Row="2"
                        Padding="28,10,28,14"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock x:Name="FooterText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
