<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FluentTasks.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentTasks.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FluentTasks">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <StackPanel Spacing="16"
                    VerticalAlignment="Center">
            <TextBlock Text="FluentTasks - OAuth test"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center" />

            <Button x:Name="LoadTaskListsButton"
                    Content="Load Tasks List"
                    Click="LoadTaskListsButton_Click"
                    HorizontalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}" />

            <TextBlock x:Name="StatusText"
                       Text="Click button to test"
                       HorizontalAlignment="Center" />

            <ListView x:Name="TaskListsView"
                      Height="300"
                      BorderBrush="Gray"
                      BorderThickness="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Window>
