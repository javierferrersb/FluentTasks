<Window x:Class="FluentTasks.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FluentTasks.UI.Controls">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Height="48"
                  Title="FluentTasks">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE73A;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <controls:NavigationPanelControl x:Name="NavigationPanel"
                                             Grid.Column="0"
                                             UserLists="{x:Bind ViewModel.UserLists, Mode=OneWay}" />

            <!-- Right Content Area -->
            <controls:TaskListControl x:Name="TaskList"
                                      Grid.Column="1"
                                      Padding="24,16,24,16"
                                      ViewModel="{x:Bind ViewModel.TaskListVM, Mode=OneWay}" />

            <!-- Settings Panel -->
            <ContentControl x:Name="SettingsContainer"
                            Grid.Column="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>