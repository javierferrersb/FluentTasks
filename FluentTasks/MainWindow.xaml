<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FluentTasks.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentTasks.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:FluentTasks.UI.Converters"
    mc:Ignorable="d"
    Title="FluentTasks">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
            <converters:DateToStringConverter x:Key="DateToStringConverter" />
            <converters:OverdueToColorConverter x:Key="OverdueToColorConverter" />
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar Area -->
        <Grid Grid.Row="0"
              Padding="16,12"
              CornerRadius="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="FluentTasks"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Content="Sync Lists"
                    Click="LoadTaskLists_Click"
                    Style="{StaticResource AccentButtonStyle}">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="R"
                                         Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1"
              Padding="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Task Lists -->
            <Grid Grid.Column="0"
                  Margin="0,0,8,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Lists Header -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8,8,0,0"
                        Padding="16,12">
                    <TextBlock Text="My Lists"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                </Border>

                <!-- Lists Content -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8">

                    <ListView x:Name="TaskListsView"
                              SelectionChanged="TaskListsView_SelectionChanged"
                              SelectionMode="Single"
                              Background="Transparent"
                              Padding="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10"
                                      Background="Transparent"
                                      CornerRadius="4">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                                <Setter Property="Padding"
                                        Value="0" />
                                <Setter Property="Margin"
                                        Value="4,2" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>
            </Grid>

            <!-- Right Panel: Tasks -->
            <Grid Grid.Column="1"
                  Margin="8,0,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tasks Header -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8,8,0,0"
                        Padding="16,12">
                    <StackPanel Spacing="16">
                        <TextBlock x:Name="TaskListTitle"
                                   Text="Select a list to view tasks"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        
                        <!-- Add Task Input -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="NewTaskInput"
                                     Grid.Column="0"
                                     PlaceholderText="Add a new task..."
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <TextBox.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Enter"
                                                         Invoked="AddTask_Enter" />
                                </TextBox.KeyboardAccelerators>
                            </TextBox>

                            <Button Grid.Column="1"
                                    Content="Add Task"
                                    Click="AddTask_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tasks Content -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8">

                    <Grid>
                        <!-- Tasks List -->
                        <ScrollViewer>
                            <ItemsRepeater x:Name="TasksView"
                                           Margin="8">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="16,12"
                                                Margin="0,0,0,8">

                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                          Click="TaskCheckbox_Click"
                                                          Tag="{Binding}"
                                                          VerticalAlignment="Center" />

                                                <!-- Display Mode -->
                                                <StackPanel Grid.Column="1"
                                                            Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                            Spacing="4"
                                                            VerticalAlignment="Center">

                                                    <!-- Title -->
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource BodyTextBlockStyle}"
                                                               TextWrapping="Wrap"
                                                               Tapped="TaskTitle_Tapped"
                                                               Tag="{Binding}" />

                                                    <!-- Notes Preview -->
                                                    <TextBlock Text="{Binding Notes}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="2"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding HasNotes, Converter={StaticResource BoolToVisibilityConverter}}"
                                                               Opacity="0.8" />

                                                    <!-- Due Date Display -->
                                                    <TextBlock Text="{Binding DueDate, Converter={StaticResource DateToStringConverter}}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{Binding IsOverdue, Converter={StaticResource OverdueToColorConverter}}"
                                                               Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>

                                                <!-- Edit Mode (unchanged) -->
                                                <Grid Grid.Column="1"
                                                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding EditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalAlignment="Center"
                                                             Tag="{Binding}">
                                                        <TextBox.KeyboardAccelerators>
                                                            <KeyboardAccelerator Key="Enter"
                                                                                 Invoked="SaveEdit_Enter" />
                                                            <KeyboardAccelerator Key="Escape"
                                                                                 Invoked="CancelEdit_Escape" />
                                                            </TextBox.KeyboardAccelerators>
                                                    </TextBox>

                                                    <Button Grid.Column="1"
                                                            Content="&#xE8FB;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            Click="SaveEdit_Click"
                                                            Tag="{Binding}"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="8,4"
                                                            ToolTipService.ToolTip="Save (Enter)" />

                                                    <Button Grid.Column="2"
                                                            Content="&#xE711;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            Click="CancelEdit_Click"
                                                            Tag="{Binding}"
                                                            Padding="8,4"
                                                            ToolTipService.ToolTip="Cancel (Esc)" />
                                                </Grid>

                                                <!-- Details Button -->
                                                <Button Grid.Column="2"
                                                        Click="TaskDetails_Click"
                                                        Tag="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        VerticalAlignment="Center"
                                                        Padding="8"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                        ToolTipService.ToolTip="Task details">
                                                    <FontIcon Glyph="&#xE70F;"
                                                              FontSize="16"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Button>

                                                <!-- Delete Button -->
                                                <Button Grid.Column="3"
                                                        Click="DeleteTask_Click"
                                                        Tag="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        VerticalAlignment="Center"
                                                        Padding="8"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                        ToolTipService.ToolTip="Delete task">
                                                    <FontIcon Glyph="&#xE74D;"
                                                              FontSize="16"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyState"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="12"
                                    Visibility="Collapsed">
                            <TextBlock Text="📋"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Opacity="0.5" />
                            <TextBlock Text="No tasks yet"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Tasks will appear here when you select a list"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock x:Name="StatusText"
                       Text="Ready - Press Ctrl+R to sync"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
