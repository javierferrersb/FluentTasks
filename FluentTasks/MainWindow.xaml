<Window x:Class="FluentTasks.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FluentTasks.UI.Controls">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Height="48"
                  Title="FluentTasks">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Square44x44Logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavPanelColumn" Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <controls:NavigationPanelControl x:Name="NavigationPanel"
                                             Grid.Column="0"
                                             UserLists="{x:Bind ViewModel.UserLists, Mode=OneWay}" />

            <!-- Right Content Area -->
            <controls:TaskListControl x:Name="TaskList"
                                      Grid.Column="1"
                                      Padding="24,16,24,16"
                                      ViewModel="{x:Bind ViewModel.TaskListVM, Mode=OneWay}"
                                      HamburgerButtonClicked="TaskList_HamburgerButtonClicked" />

            <!-- Settings Panel -->
            <ContentControl x:Name="SettingsContainer"
                            Grid.Column="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </Grid>

        <!-- Nav Panel Overlay for narrow screens -->
        <Grid x:Name="NavPanelOverlay"
              Grid.Row="1"
              Visibility="Collapsed">
            <!-- Dismiss overlay -->
            <Border Background="{ThemeResource SmokeFillColorDefaultBrush}"
                    Tapped="NavOverlayDismiss_Tapped" />
            <!-- Nav panel in overlay mode with solid background -->
            <Border HorizontalAlignment="Left"
                    Width="280"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <controls:NavigationPanelControl x:Name="OverlayNavigationPanel"
                                                 UserLists="{x:Bind ViewModel.UserLists, Mode=OneWay}" />
            </Border>
        </Grid>

        <!-- Teaching Tips for onboarding guidance -->
        <TeachingTip x:Name="WelcomeTip"
                     Title="Welcome to FluentTasks! 🎉"
                     Subtitle="Let's take a quick tour to help you get started."
                     PreferredPlacement="Center"
                     IsLightDismissEnabled="False"
                     ActionButtonContent="Let's go!"
                     ActionButtonClick="WelcomeTip_ActionButtonClick"
                     CloseButtonContent="Skip tour"
                     CloseButtonClick="TeachingTip_SkipTour">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Emoji" />
            </TeachingTip.IconSource>
        </TeachingTip>

        <TeachingTip x:Name="NavigationTip"
                     Target="{x:Bind NavigationPanel}"
                     Title="Your Task Lists"
                     Subtitle="All your task lists appear here. Click any list to view its tasks, or click the + button to create a new list."
                     PreferredPlacement="Right"
                     IsLightDismissEnabled="False"
                     ActionButtonContent="Next"
                     ActionButtonClick="NavigationTip_ActionButtonClick"
                     CloseButtonContent="Skip tour"
                     CloseButtonClick="TeachingTip_SkipTour">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="List" />
            </TeachingTip.IconSource>
        </TeachingTip>

        <TeachingTip x:Name="TaskListTip"
                     Target="{x:Bind TaskList}"
                     Title="Your Tasks"
                     Subtitle="Your tasks appear here. Use the search bar to find tasks, or filter and sort them using the buttons in the toolbar."
                     PreferredPlacement="Left"
                     IsLightDismissEnabled="False"
                     ActionButtonContent="Next"
                     ActionButtonClick="TaskListTip_ActionButtonClick"
                     CloseButtonContent="Skip tour"
                     CloseButtonClick="TeachingTip_SkipTour">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="AllApps" />
            </TeachingTip.IconSource>
        </TeachingTip>

        <TeachingTip x:Name="SyncTip"
                     Title="Stay in Sync"
                     Subtitle="Your tasks sync automatically with Google Tasks. Click the sync button anytime to manually refresh your data."
                     PreferredPlacement="Center"
                     IsLightDismissEnabled="False"
                     ActionButtonContent="Got it!"
                     ActionButtonClick="SyncTip_ActionButtonClick"
                     CloseButtonContent="Skip tour"
                     CloseButtonClick="TeachingTip_SkipTour">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Sync" />
            </TeachingTip.IconSource>
        </TeachingTip>
    </Grid>
</Window>